<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.argonomix.controllers.LoginController">
   <center>
      <VBox alignment="CENTER" spacing="20" styleClass="login-container">
         <VBox alignment="CENTER" spacing="10">
            <Label text="ARGonomix" styleClass="app-title" />
            <Label text="Personal Finance Manager" styleClass="app-subtitle" />
         </VBox>
         
         <VBox spacing="15" styleClass="login-form" maxWidth="400">
            <Label text="Welcome Back" styleClass="form-title" />
            <Label text="Sign in to your account" styleClass="form-subtitle" />
            
            <VBox spacing="10">
               <Label text="Email" />
               <TextField fx:id="emailField" promptText="Enter your email" />
               
               <Label text="Password" />
               <PasswordField fx:id="passwordField" promptText="Enter your password" />
               
               <Label fx:id="errorLabel" styleClass="error-label" visible="false" />
               
               <Button fx:id="loginButton" text="Sign In" onAction="#handleLogin" styleClass="primary-button" />
               
               <HBox alignment="CENTER" spacing="5">
                  <Label text="Don't have an account?" />
                  <Hyperlink fx:id="signupLink" text="Sign Up" onAction="#handleSignupLink" />
               </HBox>
            </VBox>
         </VBox>
      </VBox>
   </center>
</BorderPane>

