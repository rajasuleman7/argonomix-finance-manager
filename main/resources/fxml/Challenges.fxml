<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.argonomix.controllers.ChallengeController">
   <stylesheets>
      <URL value="@../css/modular.css" />
   </stylesheets>
   
   <top>
      <VBox spacing="20" padding="20" styleClass="dashboard-container">
         <!-- Header -->
         <HBox alignment="CENTER_LEFT" spacing="20">
            <Label text="Smart Savings Challenges" style="-fx-font-size: 32px; -fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="+ Create Challenge" onAction="#handleCreateChallenge" styleClass="primary-button" />
         </HBox>
         
         <!-- Active Challenges -->
         <VBox styleClass="card" spacing="15">
            <Label text="Active Challenges" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
            <VBox fx:id="challengesContainer" spacing="15" />
         </VBox>
         
         <!-- Completed Challenges -->
         <VBox styleClass="card" spacing="15">
            <Label text="Completed Challenges" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
            <VBox fx:id="completedChallengesContainer" spacing="15" />
         </VBox>
      </VBox>
   </top>
</BorderPane>


