<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.argonomix.controllers.ReportsController">
   <stylesheets>
      <URL value="@../css/modular.css" />
   </stylesheets>
   
   <top>
      <VBox spacing="20" padding="20" styleClass="dashboard-container">
         <!-- Header -->
         <HBox alignment="CENTER_LEFT" spacing="20">
            <Label text="Reports & Analytics" style="-fx-font-size: 32px; -fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" />
            <ComboBox fx:id="dateRangeCombo" />
            <Button text="Export CSV" onAction="#handleExportCSV" styleClass="secondary-button" />
            <Button text="Export PDF" onAction="#handleExportPDF" styleClass="secondary-button" />
         </HBox>
         
         <!-- Tabs -->
         <TabPane fx:id="reportsTabPane">
            <!-- Income vs Expenses Tab -->
            <Tab fx:id="incomeExpensesTab" text="Income vs Expenses" closable="false">
               <VBox styleClass="card" spacing="15" padding="20">
                  <Label text="Income vs Expenses" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
                  <BarChart fx:id="incomeExpensesChart" prefHeight="400">
                     <xAxis>
                        <CategoryAxis label="Month" />
                     </xAxis>
                     <yAxis>
                        <NumberAxis label="Amount ($)" />
                     </yAxis>
                  </BarChart>
               </VBox>
            </Tab>
            
            <!-- Net Worth Tab -->
            <Tab fx:id="netWorthTab" text="Net Worth" closable="false">
               <VBox spacing="20" padding="20">
                  <GridPane hgap="20">
                     <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints hgrow="ALWAYS" />
                        <ColumnConstraints hgrow="ALWAYS" />
                     </columnConstraints>
                     
                     <VBox styleClass="stat-card" GridPane.columnIndex="0">
                        <Label text="Total Assets" styleClass="stat-label" />
                        <Label fx:id="assetsLabel" text="$0.00" styleClass="stat-value" />
                     </VBox>
                     
                     <VBox styleClass="stat-card" GridPane.columnIndex="1">
                        <Label text="Total Liabilities" styleClass="stat-label" />
                        <Label fx:id="liabilitiesLabel" text="$0.00" styleClass="stat-value" />
                     </VBox>
                     
                     <VBox styleClass="stat-card" GridPane.columnIndex="2">
                        <Label text="Net Worth" styleClass="stat-label" />
                        <Label fx:id="netWorthLabel" text="$0.00" styleClass="stat-value" />
                     </VBox>
                  </GridPane>
               </VBox>
            </Tab>
            
            <!-- Cash Flow Tab -->
            <Tab fx:id="cashFlowTab" text="Cash Flow" closable="false">
               <VBox styleClass="card" spacing="15" padding="20">
                  <Label text="Cash Flow Forecast" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
                  <LineChart fx:id="cashFlowChart" prefHeight="400">
                     <xAxis>
                        <CategoryAxis label="Month" />
                     </xAxis>
                     <yAxis>
                        <NumberAxis label="Amount ($)" />
                     </yAxis>
                  </LineChart>
               </VBox>
            </Tab>
            
            <!-- Savings Rate Tab -->
            <Tab fx:id="savingsRateTab" text="Savings Rate" closable="false">
               <VBox styleClass="card" spacing="15" padding="20">
                  <Label text="Savings Rate Over Time" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
                  <LineChart fx:id="savingsRateChart" prefHeight="400">
                     <xAxis>
                        <CategoryAxis label="Month" />
                     </xAxis>
                     <yAxis>
                        <NumberAxis label="Rate (%)" />
                     </yAxis>
                  </LineChart>
               </VBox>
            </Tab>
         </TabPane>
      </VBox>
   </top>
</BorderPane>


