<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.argonomix.controllers.DashboardController">

   <top>
      <VBox styleClass="dashboard-container" spacing="20" padding="20">
         <!-- Welcome Section -->
         <VBox style="-fx-background-color: linear-gradient(to right, #9333ea, #3b82f6); -fx-background-radius: 12px; -fx-padding: 30px;">
            <Label fx:id="welcomeLabel" text="Welcome back!" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;" />
            <Label text="Here's your financial overview" style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 14px;" />
         </VBox>
         
         <!-- Stats Cards -->
         <GridPane hgap="20" vgap="20">
            <columnConstraints>
               <ColumnConstraints hgrow="ALWAYS" />
               <ColumnConstraints hgrow="ALWAYS" />
               <ColumnConstraints hgrow="ALWAYS" />
               <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            
            <VBox styleClass="stat-card" GridPane.columnIndex="0">
               <Label text="Total Balance" styleClass="stat-label" />
               <Label fx:id="totalBalanceLabel" text="$0.00" styleClass="stat-value" />
            </VBox>
            
            <VBox styleClass="stat-card" GridPane.columnIndex="1">
               <Label text="This Month's Spending" styleClass="stat-label" />
               <Label fx:id="monthlySpendingLabel" text="$0.00" styleClass="stat-value" />
            </VBox>
            
            <VBox styleClass="stat-card" GridPane.columnIndex="2">
               <Label text="Savings Rate" styleClass="stat-label" />
               <Label fx:id="savingsRateLabel" text="0%" styleClass="stat-value" />
            </VBox>
            
            <VBox styleClass="stat-card" GridPane.columnIndex="3">
               <Label text="Health Score" styleClass="stat-label" />
               <Label fx:id="healthScoreLabel" text="0/100" styleClass="stat-value" />
            </VBox>
         </GridPane>
         
         <!-- Main Content Grid -->
         <GridPane hgap="20" vgap="20">
            <columnConstraints>
               <ColumnConstraints hgrow="ALWAYS" minWidth="600" />
               <ColumnConstraints hgrow="ALWAYS" minWidth="300" />
            </columnConstraints>
            
            <!-- Left Column -->
            <VBox spacing="20" GridPane.columnIndex="0">
               <!-- Spending Trend Chart -->
               <VBox styleClass="card" spacing="10">
                  <Label text="Spending Trend (Last 7 Days)" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                  <LineChart fx:id="spendingTrendChart" prefHeight="200">
                     <xAxis>
                        <CategoryAxis label="Date" />
                     </xAxis>
                     <yAxis>
                        <NumberAxis label="Amount ($)" />
                     </yAxis>
                  </LineChart>
               </VBox>
               
               <!-- Recent Transactions -->
               <VBox styleClass="card" spacing="10">
                  <HBox alignment="CENTER_LEFT" spacing="10">
                     <Label text="Recent Transactions" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                     <Region HBox.hgrow="ALWAYS" />
                     <Hyperlink text="View All" onAction="#handleViewAllTransactions" />
                  </HBox>
                  <TableView fx:id="recentTransactionsTable" prefHeight="200">
                     <columns>
                        <TableColumn fx:id="transactionDateColumn" text="Date" prefWidth="120" />
                        <TableColumn fx:id="transactionDescriptionColumn" text="Description" prefWidth="200" />
                        <TableColumn fx:id="transactionCategoryColumn" text="Category" prefWidth="100" />
                        <TableColumn fx:id="transactionAmountColumn" text="Amount" prefWidth="100" />
                     </columns>
                  </TableView>
               </VBox>
               
               <!-- Budget Overview -->
               <VBox styleClass="card" spacing="10">
                  <HBox alignment="CENTER_LEFT" spacing="10">
                     <Label text="Budget Overview" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                     <Region HBox.hgrow="ALWAYS" />
                     <Hyperlink text="Manage" onAction="#handleManageBudgets" />
                  </HBox>
                  <VBox fx:id="budgetProgressContainer" spacing="10" />
               </VBox>
            </VBox>
            
            <!-- Right Column -->
            <VBox spacing="20" GridPane.columnIndex="1">
               <!-- Should I Buy This Calculator -->
               <VBox styleClass="card" spacing="15" padding="20">
                  <fx:include source="BuyCalculator.fxml" />
               </VBox>
               
               <!-- Savings Goals -->
               <VBox styleClass="card" spacing="10">
                  <HBox alignment="CENTER_LEFT" spacing="10">
                     <Label text="Savings Goals" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                     <Region HBox.hgrow="ALWAYS" />
                     <Hyperlink text="View All" onAction="#handleViewAllGoals" />
                  </HBox>
                  <VBox fx:id="goalsContainer" spacing="10" />
               </VBox>
               
               <!-- Upcoming Bills -->
               <VBox styleClass="card" spacing="10">
                  <Label text="Upcoming Bills" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                  <VBox fx:id="upcomingBillsContainer" spacing="10" />
               </VBox>
            </VBox>
         </GridPane>
      </VBox>
   </top>
</BorderPane>

