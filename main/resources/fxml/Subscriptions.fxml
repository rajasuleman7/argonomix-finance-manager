<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.argonomix.controllers.SubscriptionController">
   <stylesheets>
      <URL value="@../css/modular.css" />
   </stylesheets>
   
   <top>
      <VBox spacing="20" padding="20" styleClass="dashboard-container">
         <!-- Header -->
         <HBox alignment="CENTER_LEFT" spacing="20">
            <Label text="Subscription Audit" style="-fx-font-size: 32px; -fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="+ Add Subscription" onAction="#handleAddSubscription" styleClass="primary-button" />
         </HBox>
         
         <!-- Summary -->
         <GridPane hgap="20">
            <columnConstraints>
               <ColumnConstraints hgrow="ALWAYS" />
               <ColumnConstraints hgrow="ALWAYS" />
               <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            
            <VBox styleClass="stat-card" GridPane.columnIndex="0">
               <Label text="Total Monthly Cost" styleClass="stat-label" />
               <Label fx:id="totalMonthlyLabel" text="$0.00" styleClass="stat-value" />
            </VBox>
            
            <VBox styleClass="stat-card" GridPane.columnIndex="1">
               <Label text="Total Annual Cost" styleClass="stat-label" />
               <Label fx:id="totalAnnualLabel" text="$0.00" styleClass="stat-value" />
            </VBox>
            
            <VBox styleClass="stat-card" GridPane.columnIndex="2">
               <Label text="% of Income" styleClass="stat-label" />
               <Label fx:id="percentOfIncomeLabel" text="N/A" styleClass="stat-value" />
            </VBox>
         </GridPane>
         
         <!-- Subscriptions List -->
         <VBox styleClass="card" spacing="15">
            <Label text="Your Subscriptions" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
            <VBox fx:id="subscriptionsContainer" spacing="15" />
         </VBox>
      </VBox>
   </top>
</BorderPane>


