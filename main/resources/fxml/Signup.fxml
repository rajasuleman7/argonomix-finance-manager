<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.argonomix.controllers.SignupController">
   <center>
      <VBox alignment="CENTER" spacing="20" styleClass="login-container">
         <VBox alignment="CENTER" spacing="10">
            <Label text="ARGonomix" styleClass="app-title" />
            <Label text="Personal Finance Manager" styleClass="app-subtitle" />
         </VBox>
         
         <VBox spacing="15" styleClass="login-form" maxWidth="400">
            <Label text="Create Account" styleClass="form-title" />
            <Label text="Start managing your finances today" styleClass="form-subtitle" />
            
            <VBox spacing="10">
               <Label text="Full Name" />
               <TextField fx:id="nameField" promptText="Enter your name" />
               
               <Label text="Email" />
               <TextField fx:id="emailField" promptText="Enter your email" />
               
               <Label text="Password" />
               <PasswordField fx:id="passwordField" promptText="Create a password" />
               <ProgressBar fx:id="passwordStrengthBar" visible="false" maxWidth="Infinity" />
               <Label fx:id="passwordStrengthLabel" visible="false" styleClass="password-strength" />
               
               <Label text="Confirm Password" />
               <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password" />
               
               <Label text="Monthly Income (Optional)" />
               <TextField fx:id="monthlyIncomeField" promptText="e.g., 3000" />
               
               <Label text="Hourly Wage (Optional)" />
               <TextField fx:id="hourlyWageField" promptText="e.g., 15" />
               
               <Label fx:id="errorLabel" styleClass="error-label" visible="false" />
               
               <Button fx:id="signupButton" text="Create Account" onAction="#handleSignup" styleClass="primary-button" />
               
               <HBox alignment="CENTER" spacing="5">
                  <Label text="Already have an account?" />
                  <Hyperlink fx:id="loginLink" text="Sign In" onAction="#handleLoginLink" />
               </HBox>
            </VBox>
         </VBox>
      </VBox>
   </center>
</BorderPane>

